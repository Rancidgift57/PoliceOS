# --- OpenRouter (default) ---------------------------------------------
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
LLM_BASE_URL=https://openrouter.ai/api/v1

# --- OR Hugging Face Inference Providers (alternative) -----------------
# Get a token at https://huggingface.co/settings/tokens
# HF_TOKEN=hf_...
# LLM_BASE_URL=https://router.huggingface.co/v1

# Per-role model overrides. Pick any model string your provider serves.
EVALUATOR_MODEL=anthropic/claude-3.5-haiku
GENERATOR_MODEL=meta-llama/llama-3.3-70b-instruct
NARRATIVE_MODEL=anthropic/claude-3.5-sonnet
FALLBACK_MODEL=google/gemini-2.0-flash-001

APP_URL=https://your-deployed-frontend.example.com

# --- Sandbox backend ----------------------------------------------------
# "docker" (default): self-managed Docker daemon - see DEPLOYMENT.md Path A.
# "piston": hosted code-execution API, no Docker dependency at all - lets
#   the backend run on serverless/edge platforms. See DEPLOYMENT.md Path B.
SANDBOX_BACKEND=docker
# PISTON_URL=https://emkc.org/api/v2/piston/execute   # or your self-hosted Piston

# --- State store / caching / rate limiting -----------------------------
# Optional. If unset, everything (player state, eval cache, rate limits)
# falls back to an in-memory store scoped to a single process - fine for
# local dev, but state resets on restart and won't be shared across
# multiple backend instances.
# REDIS_URL=redis://localhost:6379/0
