# Image for the FastAPI app. Player code never runs here - it executes
# client-side in the browser via Pyodide (see
# frontend/src/lib/pyodideRunner.js) - so this image is a plain Python ASGI
# app with no Docker-in-Docker or sandboxing dependencies.
FROM python:3.11-slim

WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . /app/backend
WORKDIR /app

EXPOSE 8000
CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000"]
